{
    "version": 2,
    "framework": null,
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2",
            "includeFiles": "app/**,bootstrap/**,config/**,database/**,resources/**,routes/**,vendor/**,public/**"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "LOG_CHANNEL": "stderr",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "APP_SERVICES_CACHE": "/tmp/storage/bootstrap/services.php",
        "APP_PACKAGES_CACHE": "/tmp/storage/bootstrap/packages.php",
        "APP_CONFIG_CACHE": "/tmp/storage/bootstrap/config.php",
        "APP_ROUTES_CACHE": "/tmp/storage/bootstrap/routes.php",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie"
    }
}
